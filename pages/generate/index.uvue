<template>
	<view class="container">
		<view class="header">
			<view class="header-bg"></view>
			<view class="header-content">
				<view class="icon-wrap">
					<view class="icon">✨</view>
					<view class="icon-glow"></view>
				</view>
				<text class="title">代码生成</text>
				<text class="subtitle">根据描述生成代码</text>
			</view>
		</view>
		
		<scroll-view class="content" scroll-y>
			<view class="card">
				<view class="form-item">
					<text class="label">编程语言</text>
					<view class="selector" @click="showLangPicker">
						<text class="selector-text">{{selectedLang}}</text>
						<text class="selector-arrow">›</text>
					</view>
				</view>
				
				<view class="form-item">
					<text class="label">功能描述</text>
					<textarea v-model="desc" placeholder="请描述你想要实现的功能..." maxlength="500"/>
					<text class="count">{{desc.length}}/500</text>
				</view>
				
				<button class="submit-btn" :disabled="!desc.trim() || loading" @click="generate">
					<text>生成代码</text>
				</button>
			</view>
			
			<view class="result-card" v-if="result">
				<view class="result-header">
					<text class="result-title">生成结果</text>
					<button class="copy-btn" @click="copy">复制</button>
				</view>
				<view class="result-body">
					<text>{{result}}</text>
				</view>
			</view>
		</scroll-view>
		
		<view class="loading-mask" v-if="loading">
			<view class="loading-box">
				<view class="spin"></view>
				<text class="loading-text">正在生成代码...</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	const selectedLang = ref('JavaScript')
	const desc = ref('')
	const result = ref('')
	const loading = ref(false)
	
	const langs = ['JavaScript', 'Python', 'Java', 'TypeScript', 'Go', 'Rust', 'C++', 'PHP']
	
	const showLangPicker = () => {
		uni.showActionSheet({
			itemList: langs,
			success: (res) => { selectedLang.value = langs[res.tapIndex] }
		})
	}
	
	const saveHistory = (type: string, content: string) => {
		const history = uni.getStorageSync('chat_history') || []
		history.push({
			type: type,
			content: content,
			time: new Date().toLocaleString('zh-CN', { hour: '2-digit', minute: '2-digit' })
		})
		uni.setStorageSync('chat_history', history)
	}
	
	const generate = async () => {
		if (!desc.value.trim() || loading.value) return
		loading.value = true
		result.value = ''
		
		try {
			const res: any = await uni.request({
				url: 'https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions',
				method: 'POST',
				header: {
					'Authorization': 'Bearer sk-ws-H.EMYIRMP.kUZd.MEQCICr30HCsmUwWipre9EMlky7Y2j6mN0qcfdbR7LzNfbzIAiAcSPhq7Ef8n-iHb0bQM6ZncMHpzViKptueytzBOBtDcQ',
					'Content-Type': 'application/json'
				},
				data: {
					model: 'qwen-turbo',
					messages: [
						{ role: 'system', content: '你是一个专业的代码生成助手。请根据用户的描述生成高质量、可运行的代码。代码需要完整，包含必要的注释。' },
						{ role: 'user', content: `使用${selectedLang.value}语言，实现以下功能：${desc.value}` }
					],
					max_tokens: 2048,
					temperature: 0.7
				},
				timeout: 60000
			})
			if (res.statusCode === 200 && res.data?.choices && res.data.choices.length > 0) { 
				result.value = res.data.choices[0].message.content 
				saveHistory('generate', desc.value)
			} else { uni.showToast({ title: '生成失败: ' + JSON.stringify(res.data), icon: 'none' }) }
		} catch (e: any) {
			uni.showToast({ title: '网络错误: ' + (e.message || String(e)), icon: 'none' })
		} finally { loading.value = false }
	}
	
	const copy = () => {
		uni.setClipboardData({ data: result.value, success: () => uni.showToast({ title: '复制成功', icon: 'success' }) })
	}
</script>

<style lang="scss">
	page { background: #f5f5f5; min-height: 100%; }
	
	.container { display: flex; flex-direction: column; min-height: 100vh; }
	
	.header { position: relative; padding-bottom: 40px; }
	
	.header-bg {
		position: absolute; top: 0; left: 0; right: 0; height: 220px;
		background: linear-gradient(135deg, #10b981 0%, #059669 100%);
		border-radius: 0 0 40px 40px;
	}
	
	.header-content {
		position: relative; z-index: 1;
		padding: 60px 24px 20px; text-align: center;
	}
	
	.icon-wrap { position: relative; display: inline-block; margin-bottom: 16px; }
	
	.icon {
		width: 64px; height: 64px; background: rgba(255,255,255,0.2);
		border-radius: 50%; display: flex; align-items: center; justify-content: center;
		font-size: 28px; position: relative; z-index: 1;
		border: 2px solid rgba(255,255,255,0.4);
	}
	
	.icon-glow {
		position: absolute; top: -8px; left: -8px; right: -8px; bottom: -8px;
		background: rgba(255,255,255,0.15); border-radius: 50%;
		animation: pulse 2s infinite;
	}
	
	@keyframes pulse {
		0% { transform: scale(1); opacity: 0.5; }
		50% { transform: scale(1.15); opacity: 0.8; }
		100% { transform: scale(1); opacity: 0.5; }
	}
	
	.title {
		display: block; font-size: 22px; font-weight: 700; color: #fff;
		margin-bottom: 6px;
	}
	
	.subtitle { display: block; font-size: 14px; color: rgba(255,255,255,0.8); }
	
	.content {
		flex: 1; padding: 0 16px; padding-bottom: 30px;
		margin-top: -20px; z-index: 2;
	}
	
	.card {
		background: #fff; border-radius: 20px; padding: 24px;
		box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 20px;
	}
	
	.form-item { margin-bottom: 20px; }
	
	.form-item:last-child { margin-bottom: 0; }
	
	.label {
		display: block; font-size: 15px; font-weight: 600; color: #333;
		margin-bottom: 12px;
	}
	
	.selector {
		display: flex; align-items: center; justify-content: space-between;
		background: #f5f5f5; padding: 14px 16px; border-radius: 12px;
	}
	
	.selector-text { font-size: 15px; color: #333; }
	
	.selector-arrow { font-size: 18px; color: #999; font-weight: bold; }
	
	textarea {
		width: 100%; height: 140px; background: #f5f5f5;
		border-radius: 12px; padding: 14px 16px; font-size: 15px;
		color: #333; line-height: 1.6; box-sizing: border-box;
	}
	
	textarea::placeholder { color: #bbb; }
	
	.count { display: block; font-size: 12px; color: #999; text-align: right; margin-top: 6px; }
	
	.submit-btn {
		width: 100%; background: linear-gradient(135deg, #10b981 0%, #059669 100%);
		color: #fff; padding: 16px; border-radius: 12px; font-size: 16px; font-weight: 600;
		margin-top: 24px; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
	}
	
	.submit-btn[disabled] { background: #ccc; box-shadow: none; }
	
	.result-card {
		background: #fff; border-radius: 20px; padding: 24px;
		box-shadow: 0 4px 20px rgba(0,0,0,0.06);
	}
	
	.result-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
	
	.result-title { font-size: 16px; font-weight: 600; color: #333; }
	
	.copy-btn {
		background: linear-gradient(135deg, #10b981 0%, #059669 100%);
		color: #fff; padding: 8px 18px; border-radius: 20px; font-size: 13px;
	}
	
	.result-body {
		background: #f5f5f5; border-radius: 12px; padding: 16px;
		max-height: 400px; overflow-y: auto;
	}
	
	.result-body text {
		font-size: 14px; color: #333; line-height: 1.7;
		white-space: pre-wrap; word-break: break-all; font-family: monospace;
	}
	
	.loading-mask {
		position: fixed; top: 0; left: 0; right: 0; bottom: 0;
		background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center;
		z-index: 100;
	}
	
	.loading-box {
		background: #fff; border-radius: 20px; padding: 40px;
		display: flex; flex-direction: column; align-items: center;
	}
	
	.spin {
		width: 40px; height: 40px; border: 4px solid #f0f0f0;
		border-top: 4px solid #10b981; border-radius: 50%;
		animation: spin 1s linear infinite; margin-bottom: 16px;
	}
	
	@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
	
	.loading-text { font-size: 15px; color: #333; }
</style>
