<template>
	<view class="container">
		<view class="page-header">
			<view class="header-bg"></view>
			<view class="header-content">
				<view class="icon-wrap">
					<text>✨</text>
				</view>
				<view class="header-info">
					<text class="title">代码生成</text>
					<text class="subtitle">根据描述生成代码</text>
				</view>
			</view>
		</view>
		
		<scroll-view class="main-content" scroll-y>
			<view class="form-card">
				<view class="card-title-row">
					<text class="card-title">生成配置</text>
				</view>
				
				<view class="form-item">
					<view class="label-wrap">
						<text class="label">编程语言</text>
						<text class="label-hint">选择目标语言</text>
					</view>
					<picker :value="languageIndex" :range="languages" @change="onLanguageChange">
						<view class="picker-box">
							<text class="picker-text">{{languages[languageIndex]}}</text>
							<text class="picker-arrow">›</text>
						</view>
					</picker>
				</view>
				
				<view class="form-item">
					<view class="label-wrap">
						<text class="label">功能描述</text>
						<text class="label-hint">越详细越好</text>
					</view>
					<textarea 
						class="textarea-field" 
						v-model="description" 
						placeholder="请描述你想要实现的功能，例如：创建一个响应式的登录页面，包含用户名和密码输入框，以及登录按钮..."
						:maxlength="-1"
						auto-height
					/>
				</view>
				
				<button class="submit-btn" :disabled="loading || !description.trim()" @click="generateCode">
					<view class="btn-content" v-if="loading">
						<view class="btn-dots">
							<view class="dot"></view>
							<view class="dot"></view>
							<view class="dot"></view>
						</view>
						<text>生成中...</text>
					</view>
					<text v-else>生成代码</text>
				</button>
			</view>
			
			<view class="result-card" v-if="result">
				<view class="card-title-row">
					<text class="card-title">生成结果</text>
					<view class="card-actions">
						<button class="action-btn" @click="copyResult">
							<text>📋 复制</text>
						</button>
						<button class="action-btn" @click="regenerate">
							<text>🔄 重新生成</text>
						</button>
					</view>
				</view>
				<scroll-view class="result-scroll" scroll-y>
					<text class="code-content">{{result}}</text>
				</scroll-view>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
	import { ref } from 'vue'
	
	const languages = ['JavaScript', 'TypeScript', 'Python', 'Java', 'Go', 'Rust', 'C++', 'PHP']
	const languageIndex = ref(0)
	const description = ref('')
	const result = ref('')
	const loading = ref(false)
	
	const onLanguageChange = (e: any) => {
		languageIndex.value = e.detail.value
	}
	
	const generateCode = async () => {
		if (!description.value.trim() || loading.value) return
		
		loading.value = true
		result.value = ''
		
		try {
			const res: any = await uniCloud.callFunction({
				name: 'generate',
				data: { 
					description: description.value,
					language: languages[languageIndex.value]
				}
			})
			
			if (res.result && res.result.success) {
				result.value = res.result.data
			} else {
				uni.showToast({ title: '生成失败：' + (res.result?.message || '未知错误'), icon: 'none' })
			}
		} catch (error) {
			uni.showToast({ title: '网络错误', icon: 'none' })
		} finally {
			loading.value = false
		}
	}
	
	const regenerate = () => {
		result.value = ''
		generateCode()
	}
	
	const copyResult = () => {
		if (!result.value) return
		uni.setClipboardData({
			data: result.value,
			success: () => {
				uni.showToast({ title: '已复制', icon: 'success' })
			}
		})
	}
</script>

<style>
	page {
		height: 100%;
		background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
	}
	
	.container {
		height: 100%;
		display: flex;
		flex-direction: column;
		background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
	}
	
	.page-header {
		position: relative;
		padding: 20px 20px 16px;
		background: linear-gradient(135deg, #10b981 0%, #059669 50%, #047857 100%);
		overflow: hidden;
	}
	
	.header-bg {
		position: absolute;
		top: -50%;
		right: -20%;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
	}
	
	.header-content {
		position: relative;
		display: flex;
		align-items: center;
		gap: 16px;
	}
	
	.icon-wrap {
		width: 56px;
		height: 56px;
		background: rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(10px);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 28px;
		border: 2px solid rgba(255, 255, 255, 0.3);
	}
	
	.header-info {
		flex: 1;
	}
	
	.title {
		font-size: 22px;
		color: #fff;
		font-weight: 700;
		display: block;
	}
	
	.subtitle {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.8);
		margin-top: 4px;
		display: block;
	}
	
	.main-content {
		flex: 1;
		padding: 20px;
	}
	
	.form-card, .result-card {
		background: rgba(255, 255, 255, 0.06);
		backdrop-filter: blur(20px);
		border-radius: 24px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		margin-bottom: 20px;
		overflow: hidden;
	}
	
	.card-title-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 20px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}
	
	.card-title {
		font-size: 16px;
		font-weight: 600;
		color: #fff;
	}
	
	.card-actions {
		display: flex;
		gap: 8px;
	}
	
	.action-btn {
		padding: 6px 14px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.8);
	}
	
	.action-btn:active {
		background: rgba(255, 255, 255, 0.2);
	}
	
	.form-item {
		padding: 20px;
	}
	
	.label-wrap {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 12px;
	}
	
	.label {
		font-size: 15px;
		color: #fff;
		font-weight: 500;
	}
	
	.label-hint {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.4);
	}
	
	.picker-box {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 16px;
