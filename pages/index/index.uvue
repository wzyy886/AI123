		align-self: flex-end;
		flex-direction: row-reverse;
	}
	
	.ai-msg {
		align-self: flex-start;
	}
	
	.msg-avatar {
		width: 40px;
		height: 40px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		flex-shrink: 0;
	}
	
	.user-avatar {
		background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
	}
	
	.ai-avatar {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
