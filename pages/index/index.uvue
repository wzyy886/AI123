		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		border: 2px solid rgba(255, 255, 255, 0.3);
	}
	
	.status-dot {
		position: absolute;
		bottom: 2px;
		right: 2px;
		width: 12px;
		height: 12px;
		background: #22c55e;
		border-radius: 50%;
		border: 2px solid #6366f1;
	}
	
