		color: rgba(255, 255, 255, 0.8);
	}
	
	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.6; transform: scale(1.2); }
	}
	
	.chat-container {
		flex: 1;
		padding: 20px;
	}
	
	.welcome-section {
		margin-bottom: 24px;
	}
	
