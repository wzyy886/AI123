<template>
	<view class="container">
		<view class="chat-header">
			<view class="header-bg"></view>
			<view class="header-content">
				<view class="avatar-wrap">
					<view class="avatar">
						<text>🤖</text>
					</view>
					<view class="status-dot"></view>
				</view>
				<view class="header-info">
					<text class="name">AI代码助手</text>
					<view class="status">
						<view class="online-dot"></view>
						<text>在线</text>
					</view>
				</view>
			</view>
		</view>
		
		<scroll-view class="chat-container" scroll-y :scroll-top="scrollTop" scroll-with-animation>
			<view class="welcome-section">
				<view class="welcome-card">
					<text class="welcome-icon">👋</text>
					<text class="welcome-title">你好！我是你的AI代码助手</text>
					<text class="welcome-desc">有什么编程问题可以问我，我可以帮你写代码、查Bug、解释原理</text>
					<view class="quick-tags">
						<view class="quick-tag" v-for="(tag, i) in quickTags" :key="i" @click="sendQuickTag(tag)">
							<text>{{tag}}</text>
						</view>
					</view>
				</view>
			</view>
			
			<view class="message-list">
				<view class="message-item" v-for="(msg, index) in messages" :key="index">
					<view class="message" :class="msg.role === 'user' ? 'user-msg' : 'ai-msg'">
						<view class="msg-avatar" :class="msg.role === 'user' ? 'user-avatar' : 'ai-avatar'">
							<text>{{msg.role === 'user' ? '👤' : '🤖'}}</text>
						</view>
						<view class="msg-bubble" :class="msg.role === 'user' ? 'user-bubble' : 'ai-bubble'">
							<text class="msg-text">{{msg.content}}</text>
						</view>
					</view>
					<text class="msg-time">{{msg.time}}</text>
				</view>
			</view>
			
			<view class="loading-indicator" v-if="loading">
				<view class="loading-bubble">
					<view class="typing-dots">
						<view class="dot"></view>
						<view class="dot"></view>
						<view class="dot"></view>
					</view>
					<text>正在思考...</text>
				</view>
			</view>
		</scroll-view>
		
		<view class="input-section">
			<view class="input-bar">
				<button class="voice-btn" @click="showVoice">
					<text>🎤</text>
				</button>
				<view class="input-wrap">
					<input 
						class="input-field" 
						v-model="question" 
						placeholder="输入问题..."
						confirm-type="send"
						@confirm="sendQuestion"
					/>
					<button class="clear-btn" v-if="question" @click="clearInput">
						<text>✕</text>
					</button>
				</view>
				<button class="send-btn" :disabled="loading || !question.trim()" @click="sendQuestion">
					<text>➤</text>
				</button>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, nextTick } from 'vue'
	
	type Message = {
		role: string
		content: string
		time: string
	}
	
	const question = ref('')
	const messages = ref<Message[]>([])
	const loading = ref(false)
	const scrollTop = ref(0)
	
	const quickTags = ['JavaScript', 'Vue3', 'Python', 'React', 'TypeScript', 'Node.js']
	
	const formatTime = () => {
		const now = new Date()
		const hours = now.getHours().toString().padStart(2, '0')
		const minutes = now.getMinutes().toString().padStart(2, '0')
		return `${hours}:${minutes}`
	}
	
	const clearInput = () => {
		question.value = ''
	}
	
	const showVoice = () => {
		uni.showToast({ title: '语音输入开发中', icon: 'none' })
	}
	
	const scrollToBottom = async () => {
		await nextTick()
		scrollTop.value = 999999
	}
	
	const sendQuickTag = (tag: string) => {
		question.value = `${tag}相关的问题`
		sendQuestion()
	}
	
	const sendQuestion = async () => {
		if (!question.value.trim() || loading.value) return
		
		messages.value.push({ role: 'user', content: question.value, time: formatTime() })
		question.value = ''
		loading.value = true
		
		await scrollToBottom()
		
		try {
			const res: any = await uniCloud.callFunction({
				name: 'chat',
				data: { question: messages.value[messages.value.length - 1].content }
			})
			
			if (res.result && res.result.success) {
				messages.value.push({ role: 'ai', content: res.result.data, time: formatTime() })
			} else {
				let errorMsg = '抱歉，我无法回答这个问题：' + (res.result?.message || '未知错误')
				if (res.result?.error) {
					errorMsg += '\n错误详情: ' + res.result.error
				}
				if (res.result?.status) {
					errorMsg += '\n状态码: ' + res.result.status
				}
				if (res.result?.response) {
					errorMsg += '\n响应: ' + JSON.stringify(res.result.response)
				}
				messages.value.push({ role: 'ai', content: errorMsg, time: formatTime() })
			}
		} catch (error) {
			messages.value.push({ role: 'ai', content: '网络错误：' + (error as Error).message, time: formatTime() })
		} finally {
			loading.value = false
			await scrollToBottom()
		}
	}
</script>

<style>
	page {
		height: 100%;
		background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
	}
	
	.container {
