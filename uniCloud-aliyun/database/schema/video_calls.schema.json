{
  "bsonType": "object",
  "required": ["userId", "username", "status", "startedAt"],
  "permission": {
    "read": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "properties": {
    "_id": {
      "bsonType": "string",
      "description": "记录ID"
    },
    "userId": {
      "bsonType": "string",
      "description": "用户ID"
    },
    "username": {
      "bsonType": "string",
      "description": "用户名"
    },
    "status": {
      "bsonType": "string",
      "description": "通话状态：calling/ended"
    },
    "startedAt": {
      "bsonType": "long",
      "description": "开始时间戳"
    },
    "endedAt": {
      "bsonType": "long",
      "description": "结束时间戳"
    },
    "duration": {
      "bsonType": "long",
      "description": "通话时长（秒）"
    }
  }
}